<Window x:Class="VideoFileRenamer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="视频文件名批量整理" Height="620" Width="980" MinHeight="520" MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ThemeWindowBackground}"
        Foreground="{DynamicResource ThemeTextBrush}">
    <Grid Margin="18" Background="{DynamicResource ThemeWindowBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="素材文件夹" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBox Grid.Column="1" x:Name="FolderPathTextBox" IsReadOnly="True" MinHeight="32"
                     VerticalContentAlignment="Center" />
            <Button Grid.Column="2" x:Name="ChooseFolderButton" Content="选择文件夹"
                    MinWidth="96" MinHeight="32" Margin="10,0,0,0" Click="ChooseFolderButton_Click" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="整理后目录" VerticalAlignment="Center" Margin="0,0,10,0" />
            <TextBox Grid.Column="1" x:Name="OutputFolderPathTextBox" IsReadOnly="True" MinHeight="32"
                     VerticalContentAlignment="Center" />
            <Button Grid.Column="2" x:Name="ChooseOutputFolderButton" Content="选择目录"
                    MinWidth="96" MinHeight="32" Margin="10,0,0,0" Click="ChooseOutputFolderButton_Click" />
            <Button Grid.Column="3" x:Name="ClearOutputFolderButton" Content="清除"
                    MinWidth="64" MinHeight="32" Margin="10,0,0,0" Click="ClearOutputFolderButton_Click" />
        </Grid>

        <DockPanel Grid.Row="2" Margin="0,14,0,12" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <CheckBox x:Name="VideoOnlyCheckBox" Content="只处理常见视频格式" IsChecked="True"
                          VerticalAlignment="Center" Margin="0,0,18,0" />
                <CheckBox x:Name="IncludeSubfoldersCheckBox" Content="包含子文件夹"
                          VerticalAlignment="Center" Margin="0,0,18,0" />
                <TextBlock Text="处理方式" VerticalAlignment="Center" Margin="0,0,8,0" />
                <RadioButton x:Name="MoveModeRadioButton" Content="移动" IsChecked="True"
                             Checked="OperationModeRadioButton_Checked"
                             VerticalAlignment="Center" Margin="0,0,10,0" />
                <RadioButton x:Name="CopyModeRadioButton" Content="复制"
                             Checked="OperationModeRadioButton_Checked"
                             VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button x:Name="PreviewButton" Content="预览改名" MinWidth="92" MinHeight="32"
                        Margin="0,0,10,0" Click="PreviewButton_Click" />
                <Button x:Name="RenameButton" Content="执行改名" MinWidth="92" MinHeight="32"
                        Click="RenameButton_Click" IsEnabled="False" />
            </StackPanel>
        </DockPanel>

        <DataGrid Grid.Row="3" x:Name="PreviewDataGrid" AutoGenerateColumns="False"
                  CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                  GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                  ItemsSource="{Binding RenameItems}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="原文件名" Binding="{Binding OriginalName}" Width="2*" />
                <DataGridTextColumn Header="新文件名" Binding="{Binding NewName}" Width="2*" />
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="150" />
                <DataGridTextColumn Header="所在文件夹" Binding="{Binding DirectoryPath}" Width="2*" />
                <DataGridTextColumn Header="目标文件夹" Binding="{Binding TargetDirectoryPath}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="4" x:Name="StatusTextBlock" Margin="0,12,0,0"
                   Text="请选择素材文件夹，然后预览重命名结果。" TextWrapping="Wrap" />
    </Grid>
</Window>
